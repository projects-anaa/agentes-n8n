      "parameters": {
        "jsCode": "// resultado de la búsqueda del calendario\nconst items = $input.all();\n\nconst datosPaciente = $(\"Calcular Hora fin\").first().json;\n\n// Verifica si calendar encontro un evento real con ID\nconst hayEvento = items.some(i => i.json && i.json.id);\n\n// Devuelve el JSON con la bandera de disponibilidad\nreturn [{\n    json: {\n        ...datosPaciente,\n        disponible: !hayEvento\n    }\n}];"
