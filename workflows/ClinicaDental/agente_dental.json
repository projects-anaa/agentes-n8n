    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let horaInicio = $json.hora_inicio;\nlet duracionMin = parseInt($json.duracion || 0);\n\nlet [horas, minutos] = horaInicio.split(':').map(Number);\n\nminutos += duracionMin;\n\nif (minutos >= 60) {\n    horas += Math.floor(minutos / 60);\n    minutos = minutos % 60;\n}\n\nif (horas >= 24) {\n    horas = horas % 24;\n}\n\nconst horaFin = `${String(horas).padStart(2, '0')}:${String(minutos).padStart(2, '0')}`;\n\nreturn {\n    ...$json,\n    hora_fin: horaFin\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1760,
        400
