    {
      "parameters": {
        "jsCode": "\nconst datosAgente = $(\"AI Agent\").first().json;\nconst texto = datosAgente.output || \"\";\n\n//Extraccion datos que el usuario nos dio para cancelar\nconst matchFecha = texto.match(/fecha:\\s*([\\d-]+)/i);\nconst matchHora = texto.match(/hora:\\s*([\\d:]+)/i);\n\n//  valores por defecto catch\nconst fecha = matchFecha ? matchFecha[1].trim() : \"\";\nconst hora = matchHora ? matchHora[1].trim() : \"\";\n\nif (!fecha || !hora) {\n    throw new Error(\"No se pudo extraer la fecha o la hora del mensaje de cancelación.\");\n}\n\n// crear objeto de fecha base combinando A M D + Hora\nconst fechaBase = new Date(`${fecha}T${hora}:00`);\n\n// Calculo ±3 HORAS (6 horas en total)\nconst tresHorasEnMilisegundos = 3 * 60 * 60 * 1000;\n\nconst tiempoAfter = new Date(fechaBase.getTime() - tresHorasEnMilisegundos);\nconst tiempoBefore = new Date(fechaBase.getTime() + tresHorasEnMilisegundos);\n\n// convertir a formato iso\nconst formatISO = (date) => {\n    return date.toISOString().replace('Z', '-06:00');\n};\n\nconst afterStr = formatISO(tiempoAfter);\nconst beforeStr = formatISO(tiempoBefore);\n\nreturn [{\n    json: {\n        fecha,\n        hora,\n        after: afterStr,\n        before: beforeStr,\n        timeZone: \"America/Mexico_City\"\n    }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2000,
